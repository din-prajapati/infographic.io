# =============================================================================
# InfographicAI — Environment Variables Contract
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env (or any file with real secrets) to version control.
#
#   cp .env.example .env
#
# Variable tags:
#   # per-env  — each environment (local / staging / production) MUST have its
#                own distinct value (e.g. different RazorPay key sets per env)
#   # shared   — all environments may use the same logical value
#
# Full per-variable matrix with shapes and separation policy:
#   docs/setup/ENVIRONMENTS.md
#
# Secrets master-copy convention (local plaintext backups):
#   secrets/README.md
# =============================================================================


# =============================================================================
# CORE / SERVER
# =============================================================================
NODE_ENV=development                              # per-env
PORT=5000                                         # shared   — Express proxy port
API_PORT=3001                                     # shared   — NestJS internal port
BASE_URL=http://localhost:5000                    # per-env  — absolute base URL (used in OAuth callbacks, links)
CLIENT_URL=http://localhost:5173                  # per-env  — CORS allow-list; same host as BASE_URL in prod
DEMO_MODE=false                                   # per-env  — set true only on dedicated demo instances


# =============================================================================
# DATABASE
# =============================================================================
# Set DATABASE_URL directly — Neon provides this in: Dashboard → Connection Details
# Example shape: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/neondb?sslmode=require  # per-env

# NOTE: PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE are pruned from this file.
# They are superseded by DATABASE_URL. api/src/common/ensure-database-url.ts still reads
# them as a fallback when DATABASE_URL is absent — code removal is a follow-up story.
# See docs/setup/ENVIRONMENTS.md §2 and the Removed Variables table at the bottom of
# that document for details.


# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-unique-32-byte-random-value  # per-env


# =============================================================================
# GOOGLE OAUTH
# =============================================================================
# Create a separate OAuth 2.0 Client ID per environment in Google Cloud Console.
# https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=<local-client-id>.apps.googleusercontent.com   # per-env
GOOGLE_CLIENT_SECRET=GOCSPX-<local-client-secret>               # per-env
# Must match Authorized Redirect URI in Google Cloud Console exactly.
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback  # per-env
# Optional legacy key (distinct from OAuth client above).
GOOGLE_API_KEY=AIza...                                           # per-env (optional)


# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI — GPT-4o (TEAM and BROKERAGE tier LLM step)
OPENAI_API_KEY=sk-proj-...                        # per-env

# Ideogram — image generation (all consumer tiers)
IDEOGRAM_API_KEY=<ideogram-api-key>               # per-env

# Google Gemini — FREE and SOLO tier LLM step
# https://aistudio.google.com/apikey
GEMINI_API_KEY=AI...                              # per-env


# =============================================================================
# EMAIL — RESEND (transactional: password reset, receipts)
# =============================================================================
# Optional — when RESEND_API_KEY is absent, EmailService logs the message to
# console and never crashes (local dev default). Delivery to real users requires
# the sending domain (buildographic.com) to be SPF/DKIM-verified in Resend.
# https://resend.com → API Keys / Domains
RESEND_API_KEY=                                   # per-env  — empty locally = console fallback
EMAIL_FROM=Buildographic <noreply@buildographic.com>  # shared — domain must be verified in Resend


# =============================================================================
# OBSERVABILITY — SENTRY
# =============================================================================
# One Sentry project; tag environment via Sentry SDK (environment=staging/production).
# Leave empty locally to disable Sentry.
# https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=                                       # shared   — NestJS backend
VITE_SENTRY_DSN=                                  # shared   — React frontend (Vite build-time)


# =============================================================================
# PAYMENTS — RAZORPAY (primary, INR)
# =============================================================================
# Key ID + Secret from: https://dashboard.razorpay.com/app/keys
# LOCAL + STAGING: rzp_test_* keys   |   PRODUCTION: rzp_live_* keys only
RAZORPAY_KEY_ID=rzp_test_...                      # per-env
RAZORPAY_KEY_SECRET=<razorpay-key-secret>         # per-env
RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret> # per-env  — one secret per webhook endpoint

# Seconds buffer before subscription start_at; user must finish auth within this window
RAZORPAY_SUBSCRIPTION_START_BUFFER_SECONDS=900    # shared   (default 900 = 15 min)

# Plan IDs — create in RazorPay Dashboard: Products → Plans
# Use test plan IDs on local+staging; live plan IDs on production.
# Primary keys (_MONTHLY / _ANNUAL); _SOLO etc. are legacy fallbacks still read by payments.service.ts
RAZORPAY_PLAN_SOLO_MONTHLY=plan_...               # per-env
RAZORPAY_PLAN_SOLO_ANNUAL=plan_...                # per-env
RAZORPAY_PLAN_SOLO=plan_...                       # per-env  — legacy fallback
RAZORPAY_PLAN_TEAM_MONTHLY=plan_...               # per-env
RAZORPAY_PLAN_TEAM_ANNUAL=plan_...                # per-env
RAZORPAY_PLAN_TEAM=plan_...                       # per-env  — legacy fallback
RAZORPAY_PLAN_BROKERAGE_MONTHLY=plan_...          # per-env  — PT-06 deferred; configure when ready
RAZORPAY_PLAN_BROKERAGE_ANNUAL=plan_...           # per-env  — PT-06 deferred
RAZORPAY_PLAN_BROKERAGE=plan_...                  # per-env  — legacy fallback
RAZORPAY_PLAN_API_STARTER=plan_...                # per-env
RAZORPAY_PLAN_API_GROWTH=plan_...                 # per-env

# Frontend (Vite build-time) — Key ID only, no secret
VITE_RAZORPAY_KEY_ID=rzp_test_...                 # per-env  — must match RAZORPAY_KEY_ID above


# =============================================================================
# PAYMENTS — STRIPE (optional, disabled by default)
# =============================================================================
# Set STRIPE_ENABLED=true only when Stripe integration is activated.
# https://dashboard.stripe.com/apikeys
STRIPE_ENABLED=false                              # shared   — flip to true to activate Stripe
STRIPE_SECRET_KEY=sk_test_...                     # per-env  — optional; ignored when STRIPE_ENABLED=false
STRIPE_PUBLISHABLE_KEY=pk_test_...                # per-env  — optional
STRIPE_WEBHOOK_SECRET=whsec_...                   # per-env  — optional; one secret per endpoint
# Price IDs — create in Stripe Dashboard
STRIPE_PLAN_SOLO=price_...                        # per-env  — optional
STRIPE_PLAN_TEAM=price_...                        # per-env  — optional
STRIPE_PLAN_BROKERAGE=price_...                   # per-env  — optional
STRIPE_PLAN_API_STARTER=price_...                 # per-env  — optional
STRIPE_PLAN_API_GROWTH=price_...                  # per-env  — optional


# =============================================================================
# FRONTEND (VITE_* — build-time, injected by Vite)
# =============================================================================
# Override only when pointing local frontend at a remote API.
VITE_API_BASE=/api/v1                             # shared   — REST base path (default /api/v1)
VITE_API_URL=http://localhost:3001                # per-env  — WebSocket / Socket.io base URL
VITE_APP_BUILD=dev                                # per-env  — build tag shown in UI footer
VITE_E2E_GENERATION_POLL_ONLY=false               # per-env  — set true in E2E test runs only
VITE_STORAGE_PREFIX=infographicai                 # shared   — localStorage key prefix


# =============================================================================
# LOCAL DEVELOPMENT UTILITIES (not deployed)
# =============================================================================
# Registered user for npm run test:payment and npm run test:payment:ensure-user
# TEST_USER_EMAIL=your-test-user@example.com
# TEST_USER_PASSWORD=your-secure-password
# TEST_USER_NAME=Optional Display Name
# TEST_USER_ORG_NAME=Optional New Org Name

# Playwright E2E (npm run test:e2e:editor) — local headed Chrome, maximized
# PLAYWRIGHT_BASE_URL=http://localhost:5000


# =============================================================================
# PRUNED VARIABLES (removed in US-LAUNCH-009)
# =============================================================================
# The following keys were in a previous .env.example but are not actively used:
#
#   SESSION_SECRET   — not read in api/src or server (grep confirms)
#   PADDLE_API_KEY   — not configured; dead-letter code remains in server/
#                      (follow-up cleanup story required)
#   PADDLE_WEBHOOK_SECRET — same as above
#   PAYPAL_CLIENT_ID — not configured; dead-letter code remains in server/
#   PAYPAL_CLIENT_SECRET  — same as above
#
# See docs/setup/ENVIRONMENTS.md §9 for details.
