# ============================================
# Infographic Editor - Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!
#
# Usage: cp .env.example .env
# Then edit .env with your actual values
#
# For separate environments, use:
#   Development/Test: cp .env.development.example .env  (Razorpay TEST keys, test plan IDs)
#   Production:       cp .env.production.example .env   (Razorpay LIVE keys, live plan IDs)
# See .env.development.example and .env.production.example in project root.
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Use PG* vars (recommended - avoids credentials-in-URI security warnings).
# When DATABASE_URL is unset, Nest (api/src/main.ts), Prisma config, Drizzle, and
# scripts call ensureDatabaseUrlFromPgEnv() which sets:
#   postgresql://${encodeURIComponent(PGUSER)}:${encodeURIComponent(PGPASSWORD)}@${PGHOST}:${PGPORT}/${PGDATABASE}?sslmode=require
# Defaults: PGPORT=5432, PGDATABASE=neondb (Neon). Use sslmode=require for Neon/cloud.
PGDATABASE=infographic_db
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=password
# Optional: set DATABASE_URL directly (not recommended - triggers security scanners)
# DATABASE_URL=postgresql://user:password@localhost:5432/infographic_db

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
API_PORT=3001
NODE_ENV=development
BASE_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate a secure JWT secret: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
# Generate a secure session secret: openssl rand -base64 64
SESSION_SECRET=your-session-secret-change-in-production

# Google OAuth (Sign in with Google)
# Get from: https://console.cloud.google.com/apis/credentials → Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
# Must match exactly the redirect URI in Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ============================================
# AI SERVICES
# ============================================
# OpenAI API key (required for AI features)
OPENAI_API_KEY=sk-proj-...
# Ideogram API key (required for image generation)
IDEOGRAM_API_KEY=...
# Google API key (optional)
GOOGLE_API_KEY=...

# ============================================
# ERROR TRACKING - SENTRY
# ============================================
# Get DSN from: https://sentry.io → Project Settings → Client Keys (DSN)
# NestJS backend
SENTRY_DSN=
# React frontend (Vite)
VITE_SENTRY_DSN=

# ============================================
# PAYMENT PROVIDERS - RAZORPAY
# ============================================
# Backend (Nest API) reads from this ROOT .env file. Use exact names below.
# Get Key ID + Secret from: https://dashboard.razorpay.com/app/keys
# (Frontend uses VITE_RAZORPAY_KEY_ID in client/.env.development — Key ID only.)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...
# Seconds to add to "now" for subscription start_at; user must complete auth before this elapses (default: 900 = 15 min)
RAZORPAY_SUBSCRIPTION_START_BUFFER_SECONDS=900
# Infographic Product - Plan IDs (create in Razorpay: Products → Plans)
# App uses _MONTHLY/_ANNUAL by billing period. Default (RAZORPAY_PLAN_SOLO etc.) optional fallback.
# SOLO: InfographicAI - SOLO Monthly / InfographicAI - SOLO Annual
RAZORPAY_PLAN_SOLO_MONTHLY=plan_...
RAZORPAY_PLAN_SOLO_ANNUAL=plan_...
# TEAM: InfographicAI - TEAM Monthly / InfographicAI - TEAM Annual
RAZORPAY_PLAN_TEAM_MONTHLY=plan_...
RAZORPAY_PLAN_TEAM_ANNUAL=plan_...
# BROKERAGE (Monthly/Annual if created)
RAZORPAY_PLAN_BROKERAGE_MONTHLY=plan_...
RAZORPAY_PLAN_BROKERAGE_ANNUAL=plan_...
RAZORPAY_PLAN_API_STARTER=plan_...
RAZORPAY_PLAN_API_GROWTH=plan_...

# Registered user for npm run test:payment and npm run test:payment:ensure-user
# TEST_USER_EMAIL=your-test-user@example.com
# TEST_USER_PASSWORD=your-secure-password
# TEST_USER_NAME=Optional Display Name
# TEST_USER_ORG_NAME=Optional New Org Name

# Playwright e2e (npm run test:e2e:editor) — local headed Chrome, maximized
# PLAYWRIGHT_BASE_URL=http://localhost:5000

# ============================================
# PAYMENT PROVIDERS - STRIPE
# ============================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs - Create prices in Stripe dashboard first
STRIPE_PLAN_SOLO=price_...
STRIPE_PLAN_TEAM=price_...
STRIPE_PLAN_BROKERAGE=price_...
STRIPE_PLAN_API_STARTER=price_...
STRIPE_PLAN_API_GROWTH=price_...
