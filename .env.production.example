# ============================================
# PRODUCTION ENVIRONMENT
# ============================================
# Copy to .env.production or .env on production server.
# Use Razorpay LIVE Mode keys and LIVE plan IDs only.
# NEVER use test keys or test plan IDs in production.
#
# Usage (on server): cp .env.production.example .env
# Or set these in your hosting provider's env (Vercel, Railway, etc.)
# ============================================

# ============================================
# DATABASE CONFIGURATION — Neon (DB) + Railway (app hosting)
# ============================================
# This product uses Neon for Postgres and Railway only for app hosting.
# The app runs as a single always-on container, so use Neon's DIRECT
# (non-pooled) connection string — simplest and correct for a long-lived
# server. Copy it from the Neon console for the branch you are deploying
# (production branch for prod, a separate branch per staging/preview).
#
#   Neon console → Project → Branches → <branch> → Connection string
#   Pick "Direct connection" (host WITHOUT "-pooler"), require SSL.
#
# Example (replace with your branch's values):
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxxx.us-west-2.aws.neon.tech/neondb?sslmode=require
#
# Leave PG* unset when DATABASE_URL is provided (DATABASE_URL wins).
# Only set PG* instead of DATABASE_URL if you prefer component vars; the app
# builds the URL via ensureDatabaseUrlFromPgEnv() and appends ?sslmode=require.
#
# Optional (only if you choose Neon's POOLED endpoint for runtime): add the
# pooled host with "&pgbouncer=true" as DATABASE_URL and keep the DIRECT host
# for schema ops. Not required for this single-container setup.
# DATABASE_URL=postgresql://...-pooler.../neondb?sslmode=require&pgbouncer=true

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
API_PORT=3001
NODE_ENV=production
BASE_URL=https://your-app.com
CLIENT_URL=https://your-app.com

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate: openssl rand -base64 32
JWT_SECRET=your-production-jwt-secret
# Generate: openssl rand -base64 64
SESSION_SECRET=your-production-session-secret

# ============================================
# AI SERVICES
# ============================================
OPENAI_API_KEY=sk-proj-...
IDEOGRAM_API_KEY=...
GOOGLE_API_KEY=

# ============================================
# PAYMENT - RAZORPAY (LIVE MODE ONLY)
# ============================================
# From Dashboard with Test Mode OFF: Settings → API Keys → Live Mode Keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=whsec_...
# Infographic Product - Plan IDs (match Razorpay Dashboard plan names in Live Mode)
# App uses _MONTHLY/_ANNUAL by billing period. Default (RAZORPAY_PLAN_SOLO etc.) optional fallback.
# SOLO: Monthly & Annual plans
RAZORPAY_PLAN_SOLO_MONTHLY=plan_...
RAZORPAY_PLAN_SOLO_ANNUAL=plan_...
# TEAM: Monthly & Annual plans
RAZORPAY_PLAN_TEAM_MONTHLY=plan_...
RAZORPAY_PLAN_TEAM_ANNUAL=plan_...
# BROKERAGE: Monthly & Annual plans (optional)
RAZORPAY_PLAN_BROKERAGE_MONTHLY=plan_...
RAZORPAY_PLAN_BROKERAGE_ANNUAL=plan_...
# API tiers (if used)
RAZORPAY_PLAN_API_STARTER=plan_...
RAZORPAY_PLAN_API_GROWTH=plan_...

# ============================================
# PAYMENT - STRIPE (LIVE MODE - OPTIONAL)
# ============================================
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLAN_SOLO=price_...
STRIPE_PLAN_TEAM=price_...
STRIPE_PLAN_BROKERAGE=price_...
STRIPE_PLAN_API_STARTER=price_...
STRIPE_PLAN_API_GROWTH=price_...

# ============================================
# FRONTEND (VITE) - Production
# ============================================
# Vite loads these when mode=production (npm run build)
VITE_API_URL=https://your-api.com
VITE_API_BASE=/api/v1
VITE_CLIENT_URL=https://your-app.com
VITE_RAZORPAY_KEY_ID=rzp_live_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
VITE_ENABLE_STRIPE=false
VITE_ENABLE_ANALYTICS=true
